{
  "name": "staticmap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx/esm src/server.ts",
    "dev": "tsx watch src/server.ts",
    "check": "prettier --write . && tsc --noEmit",
    "test": "vitest --run",
    "clean": "rm -rf ./dist"
  },
  "dependencies": {
    "@turf/helpers": "^7.3.5",
    "canvas": "^3.2.3",
    "express": "^5.2.1",
    "geojson": "^0.5.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "proj4": "^2.20.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
